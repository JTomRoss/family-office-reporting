# FO Reporting – Environment Variables (example)
# Copiar a .env y ajustar valores

# App
FO_DEBUG=false

# Database
# FO_DATABASE_URL=sqlite:///data/db/fo_reporting.db

# Backend
FO_BACKEND_HOST=0.0.0.0
FO_BACKEND_PORT=8000

# Frontend
FO_FRONTEND_PORT=8501
FO_BACKEND_URL=http://localhost:8000

# CORS – Orígenes permitidos (separados por coma)
# FO_CORS_ORIGINS=["http://localhost:8501","http://127.0.0.1:8501"]

# OpenAI (Operacional > Revisión, auditoría LLM). Copiar a .env con tu clave.
# OPENAI_API_KEY=sk-...
